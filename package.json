{
  "name": "polymarket-wizard",
  "private": true,
  "version": "1.0.0",
  "description": "A guarded Netlify + React trading console for one Polymarket bot wallet.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:netlify": "netlify dev -d dist -f netlify/functions --port 8888",
    "build": "tsc && vite build",
    "functions:build": "netlify functions:build --src netlify/functions --functions .netlify/functions-test",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "netlify-cli": "^26.1.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "@polymarket/builder-relayer-client": "^0.0.10",
    "@polymarket/builder-signing-sdk": "^1.0.0",
    "@polymarket/clob-client-v2": "^1.0.6",
    "lucide-react": "^1.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.52.2"
  },
  "overrides": {
    "ws": "^8.21.0"
  }
}
